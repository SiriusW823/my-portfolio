{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "my-portfolio",
  "main": "server/worker.ts",
  "compatibility_date": "2026-07-10",
  "assets": {
    "directory": "./dist/public",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  }
}
